{
  "name": "@anion155/react-rxjs-hooks",
  "version": "0.2.0",
  "description": "React utility hooks",
  "author": {
    "name": "Anton Mikhailov",
    "email": "anion155@gmail.com"
  },
  "repository": "github:anion155/react-hooks",
  "license": "MIT",
  "private": false,
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "files": [
    "./utils.js",
    "./utils.d.ts",
    "./dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": {
        "production": "./dist/index.prod.mjs",
        "default": "./dist/index.mjs"
      },
      "default": {
        "production": "./dist/index.prod.js",
        "default": "./dist/index.js"
      }
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": {
        "production": "./dist/utils.prod.mjs",
        "default": "./dist/utils.mjs"
      },
      "default": {
        "production": "./dist/utils.prod.js",
        "default": "./dist/utils.js"
      }
    }
  },
  "scripts": {
    "lint": "eslint src",
    "test": "jest src",
    "build": "rimraf dist && rollup --bundleConfigAsCjs --config",
    "bump-version": "run-with-args 'pnpm version $1 && git add ./package.json && git commit -m \"bump: react-rxjs-hooks $1\" && git tag \"react-rxjs-hooks-v$1\"'",
    "prepack": "npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "@jest/globals": "^29.5.0",
    "@monorepo/config": "workspace:*",
    "@testing-library/react": "^13.4.0",
    "@types/react": "^18.2.0",
    "@types/use-sync-external-store": "^0.0.3",
    "eslint": "^8.39.0",
    "jest": "^29.5.0",
    "prettier": "^2.8.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^3.0.2",
    "rollup": "^3.21.0",
    "rxjs": "^7.8.1",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "@anion155/react-hooks": "workspace:^",
    "tslib": "^2.5.0",
    "use-sync-external-store": "^1.2.0"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "rxjs": "^7.5.7"
  }
}
